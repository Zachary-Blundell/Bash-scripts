#!/bin/bash

# Manage dotfiles: create ~/dotfiles, set $DOTFILES_DIR, push, stow, merge.

set -euo pipefail
IFS=$'\n\t'

###############################################################################
# Constants
###############################################################################
readonly ZSHENV="${HOME}/.zshenv"

readonly GREEN='\033[0;32m'
readonly RED='\033[0;31m'
readonly NC='\033[0m' # No Color

###############################################################################
# Logging helpers
###############################################################################
log() { printf '%b\n' "$*"; }
log_info() { printf '%b\n' "${GREEN}%s${NC}\n" "$*"; }
log_error() { printf '%b\n' "${RED}Error:${NC} $*" >&2; }

###############################################################################
# User-interaction helpers
###############################################################################
confirm() {
  local prompt=${1:-"Continue"}
  local reply
  read -r -n1 -p "${prompt} (y/n): " reply
  printf '\n'
  [[ $reply =~ ^[Yy]$ ]]
}

pause() {
  read -r -n1 -s -p "Press any key to continue…"
  printf '\n'
}

###############################################################################
# Dotfiles-directory helpers
###############################################################################
ask_dotfiles_path() {
  local rel_path
  read -r -p "Enter directory path relative to \$HOME (default: dotfiles): " rel_path
  rel_path=${rel_path:-dotfiles}
  printf '%s/dotfiles\n' "${HOME}/${rel_path%/}"
}

ensure_dotfiles_dir() {
  local path
  path=$(ask_dotfiles_path)

  if [[ -d $path ]]; then
    log_info "Using dotfiles directory at $path"
  else
    log_error "Directory $path does not exist."
    if confirm "Create $path?"; then
      log_info "Creating directory…"
      mkdir -p -- "$path"
    else
      log "Abort."
      exit 1
    fi
  fi
  printf '%s\n' "$path"
}

export_dotfiles_dir() {
  local path=$1

  if grep -q '^export DOTFILES_DIR=' "$ZSHENV"; then
    log_info "Updating DOTFILES_DIR in $ZSHENV"
    sed -i "s|^export DOTFILES_DIR=.*|export DOTFILES_DIR=${path}|" "$ZSHENV"
  else
    log_info "Adding DOTFILES_DIR to $ZSHENV"
    printf 'export DOTFILES_DIR=%s\n' "$path" >>"$ZSHENV"
  fi

  log "Run 'source $ZSHENV' to apply in the current shell."
}

init_dotfiles_dir() {
  # If DOTFILES_DIR already valid, keep it; otherwise prompt & export.
  if [[ -n ${DOTFILES_DIR:-} && -d $DOTFILES_DIR ]]; then
    log_info "Using dotfiles directory at $DOTFILES_DIR"
  else
    log_error "DOTFILES_DIR unset or invalid."
    local new_path
    new_path=$(ensure_dotfiles_dir)
    export DOTFILES_DIR=$new_path
    export_dotfiles_dir "$new_path"
  fi
}

###############################################################################
# Git / Stow helpers
###############################################################################
push_dots() {
  (
    cd -- "$DOTFILES_DIR"
    git add -A
    local msg
    read -r -p "Commit message (default: Backup): " msg
    msg=${msg:-Backup}
    git commit -m "$msg"
    git push
  )
}

stow_dotfiles() {
  (
    cd -- "$DOTFILES_DIR"
    stow .
  )
}

merge_files() {
  (
    cd -- "$DOTFILES_DIR"
    local current_branch
    current_branch=$(git symbolic-ref --quiet --short HEAD)

    read -r -p "Branch to merge from (default: $current_branch): " branch
    branch=${branch:-$current_branch}

    if [[ $branch == "$current_branch" ]]; then
      log_error "Cannot merge from the current branch."
      return 1
    fi

    local path
    read -r -p "Path to file/folder to merge (e.g. .zshrc): " path
    [[ -z $path ]] && {
      log_error "No path provided."
      return 1
    }

    log "Fetching and checking out $path from $branch…"
    git fetch origin "$branch"
    git checkout "$branch" -- "$path"
    git add -- "$path"

    local msg
    read -r -p "Merge commit message (default: Merged $path from $branch): " msg
    msg=${msg:-"Merged $path from $branch"}
    git commit -m "$msg"
  )
}

###############################################################################
# Main menu
###############################################################################
init_dotfiles_dir

while :; do
  clear
  log_info "Active dotfiles directory: $DOTFILES_DIR"
  cat <<'EOF'

Select an option:
  a) Push all changes (git add/commit/push)
  s) Stow dotfiles                 (GNU stow)
  m) Merge file/folder from branch (git checkout)
  q) Quit

EOF
  read -r -p "Choice: " choice
  case $choice in
  a)
    push_dots
    pause
    ;;
  s)
    stow_dotfiles
    pause
    ;;
  m)
    merge_files
    pause
    ;;
  q)
    log "Bye."
    break
    ;;
  *)
    log_error "Invalid option."
    pause
    ;;
  esac
done
